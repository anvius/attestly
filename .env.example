# Environment variables for local development
# Copy this file to .env and fill in the values
# cp .env.example .env

# ─── Backend ──────────────────────────────────────────────────────────────────

# HTTP port for the backend API server
PORT=3000

# SQLite database path
DB_PATH=./doccum.db

# HMAC secret for CAPTCHA token signing
# Required in production — generate with: openssl rand -hex 32
CAPTCHA_SECRET=

# Set to "true" to disable email sending (useful for local dev / CI)
DISABLE_SMTP=true

# ─── Frontend ─────────────────────────────────────────────────────────────────

# URL of the backend API (used at build time for SSR and at runtime for CSR)
VITE_API_BASE_URL=http://localhost:3000

# Optional: URL of your GoatCounter analytics instance (leave blank to disable)
VITE_GOATCOUNTER_URL=

# ─── Docker Compose ───────────────────────────────────────────────────────────

# Exposed host ports for Docker Compose (local override)
BACKEND_PORT=3001
FRONTEND_PORT=4174
ANALYTICS_PORT=8080

# ─── GoatCounter Analytics ────────────────────────────────────────────────────

# Admin account for the self-hosted GoatCounter instance
# ⚠ Change BOTH values before any public deployment
GOATCOUNTER_EMAIL=admin@your-domain.example
GOATCOUNTER_PASSWORD=change-me-in-production

# ─── SMTP (contact form) ──────────────────────────────────────────────────────
# Configure in etc/config.json: contact.smtp.{host,port,username,password,...}
# or override with SMTP_HOST, SMTP_PASSWORD env vars if you extend create-app.ts
