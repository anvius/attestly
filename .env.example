# Environment variables for local development
# Copy this file to .env and fill in the values
# cp .env.example .env

# ─── Backend ──────────────────────────────────────────────────────────────────

# HTTP port for the backend API server (default: 3000)
PORT=3000

# SQLite database path — use /data/doccum.db in production (Docker volume)
DB_PATH=./doccum.db

# HMAC secret for CAPTCHA token signing.
# Required in production — a random key is generated per-process if not set,
# which causes CAPTCHA tokens to become invalid on restart.
# Generate with: openssl rand -hex 32
CAPTCHA_SECRET=

# Set to "1" to disable email sending (useful for local dev / CI).
# SMTP is also automatically disabled if contact.smtp.host in config.json
# is still set to the default placeholder value "smtp.example.com".
DISABLE_SMTP=1

# SMTP credentials — override the values in etc/config.json.
# Keep credentials out of the config file and set them here (or in Dokploy).
# Non-sensitive SMTP settings (host, port, fromEmail, toEmail) go in config.json.
SMTP_USERNAME=
SMTP_PASSWORD=

# ─── Frontend (build-time) ────────────────────────────────────────────────────

# URL of the backend API — baked into the frontend at build time.
# Development: http://localhost:3000
# Production:  https://api.doccum.com
VITE_API_BASE_URL=http://localhost:3000

# Optional: URL of your GoatCounter analytics instance (leave blank to disable).
# Production: https://stats.doccum.com
VITE_GOATCOUNTER_URL=

# ─── Docker Compose (local port overrides) ────────────────────────────────────

# Exposed host ports for local Docker Compose (override defaults to avoid conflicts)
BACKEND_PORT=3001
FRONTEND_PORT=4174
ANALYTICS_PORT=8080

# ─── GoatCounter Analytics ────────────────────────────────────────────────────

# Admin account for the self-hosted GoatCounter instance.
# Used by compose.dokploy.yaml — set these in Dokploy environment settings.
# ⚠ Change BOTH values before any public deployment.
GOATCOUNTER_EMAIL=admin@your-domain.example
GOATCOUNTER_PASSWORD=change-me-in-production
